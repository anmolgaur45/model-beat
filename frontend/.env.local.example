# Copy this file to .env.local and fill in your values

DATABASE_HOST=<cloud-sql-public-ip>
DATABASE_PORT=5432
DATABASE_NAME=ainews
DATABASE_USER=ainews_app
DATABASE_PASSWORD=<password>
# Paste full contents of server-ca.pem here (optional, enables SSL cert verification)
DATABASE_SSL_CA=

INGEST_SECRET=<random secret for recluster endpoint>

# Public URL — used for OpenGraph metadataBase
# Set to your production domain before deploying, e.g. https://ainewscalendar.com
NEXT_PUBLIC_URL=http://localhost:3000
